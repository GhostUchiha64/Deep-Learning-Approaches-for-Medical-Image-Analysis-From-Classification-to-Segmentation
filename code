ResNet (Classification) — Pseudocode

# Model: Residual Block
function ResidualBlock(x):
    y = ConvBNReLU(x, k=3, c_out)        # conv → batchnorm → ReLU
    y = ConvBN(y, k=3, c_out)            # conv → batchnorm (no ReLU yet)
    if shape(x) != shape(y):
        x = Projection1x1(x, c_out)      # match channels/stride if needed
    out = ReLU(y + x)                     # skip connection (residual)
    return out

# Model: ResNet (stack residual blocks + global pooling + linear)
function ResNet(input_image):
    z = StemConvBNReLU(input_image)       # initial conv + BN + ReLU + pool
    for stage in [S1, S2, S3, S4]:        # each stage has N residual blocks
        for i in range(N_stage):
            z = ResidualBlock(z)
    z = GlobalAveragePool(z)              # HxW → 1x1 per channel
    logits = Linear(z, num_classes)
    return logits

# Training
for epoch in range(E):
    for (x, y_true) in train_loader:
        logits = ResNet(x)
        loss = CrossEntropyLoss(logits, y_true)
        optimizer.zero_grad()
        loss.backward()                   # gradients flow through skips
        optimizer.step()

# Inference
function PredictResNet(x):
    logits = ResNet(x)
    probs = Softmax(logits)
    y_hat = argmax(probs)
    return y_hat, probs

YOLO (Object Detection) — Pseudocode

# Model: Single-stage detector (grid-based)
function YOLO(image):
    F = BackboneCNN(image)                            # feature extractor
    P = DetectionHead(F)                              # tensor [S, S, B*(5+C)]
    # For each grid cell: B boxes; each box predicts (cx, cy, w, h, obj) + C classes
    return P

# Training: multi-part loss (localization + objectness + classification)
for epoch in range(E):
    for (image, targets) in train_loader:
        # targets: list of GT boxes [cx, cy, w, h, class_id]
        P = YOLO(image)
        loss_loc = 0; loss_obj = 0; loss_cls = 0
        for each grid cell g:
            # assign GT box to best anchor in cell g
            gt = MatchGTToAnchors(g, targets)
            if gt exists:
                loss_loc += L2((P[g].cx, P[g].cy, P[g].w, P[g].h), (gt.cx, gt.cy, gt.w, gt.h))
                loss_obj += BCE(P[g].obj, 1)
                loss_cls += CE(P[g].class_logits, gt.class_id)
            else:
                loss_obj += BCE(P[g].obj, 0)
        loss = λ_loc*loss_loc + λ_obj*loss_obj + λ_cls*loss_cls
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

# Inference: decode boxes + NMS
function DetectYOLO(image, conf_thresh, nms_iou):
    P = YOLO(image)
    boxes = Decode(P)                                  # convert grid preds to image coords
    boxes = Filter(boxes, score > conf_thresh)
    boxes = NonMaximumSuppression(boxes, iou_thr=nms_iou)
    return boxes                                       # [x1, y1, x2, y2, class, score]


U-Net (Segmentation) — Pseudocode
# Model: Encoder-Decoder with skip connections
function DoubleConv(x, c_out):
    x = ConvBNReLU(x, k=3, c_out)
    x = ConvBNReLU(x, k=3, c_out)
    return x

function UNet(image):
    # Encoder (downsampling)
    e1 = DoubleConv(image, 64);     d1 = MaxPool(e1)
    e2 = DoubleConv(d1,    128);    d2 = MaxPool(e2)
    e3 = DoubleConv(d2,    256);    d3 = MaxPool(e3)
    e4 = DoubleConv(d3,    512);    d4 = MaxPool(e4)

    # Bottleneck
    b  = DoubleConv(d4,    1024)

    # Decoder (upsampling + concat with encoder features)
    u4 = UpConv(b, 512);    u4 = Concat(u4, e4);    u4 = DoubleConv(u4, 512)
    u3 = UpConv(u4,256);    u3 = Concat(u3, e3);    u3 = DoubleConv(u3, 256)
    u2 = UpConv(u3,128);    u2 = Concat(u2, e2);    u2 = DoubleConv(u2, 128)
    u1 = UpConv(u2, 64);    u1 = Concat(u1, e1);    u1 = DoubleConv(u1, 64)

    logits = Conv1x1(u1, num_classes)  # per-pixel logits
    return logits

# Training (use Dice or BCE/CE losses; often combined)
for epoch in range(E):
    for (image, mask_true) in train_loader:
        logits = UNet(image)                           # [N, C, H, W]
        if num_classes == 1:
            probs = Sigmoid(logits)
            loss  = DiceLoss(probs, mask_true) + BCE(probs, mask_true)
        else:
            probs = Softmax(logits, dim=channels)
            loss  = DiceLossMulti(probs, mask_true) + CE(logits, mask_true)
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()

# Inference
function SegmentUNet(image, threshold=0.5):
    logits = UNet(image)
    if num_classes == 1:
        probs = Sigmoid(logits)
        mask  = (probs > threshold)
    else:
        mask  = argmax(Softmax(logits), dim=channels)
    return mask
